# --- Condo app credentials ---
LOGIN_EMAIL=your-email@example.com
LOGIN_PASSWORD=your-password-here

# --- Persistent master token (captured from the app) ---
# The long-lived Bearer token the app sends on superTokenCheck / loginCheck.
# It survives logout and app restarts. Capture it from the Authorization
# header of the app's superTokenCheck request via a proxy (e.g. HTTP Toolkit).
# The login call REQUIRES this header in addition to email/password - without
# it, login is rejected with 403 "Access Denied".
# Treat this like a password: it is a persistent key to your account.
MASTER_TOKEN=RWev4r...paste_full_token_here...NwoI=

# --- Device identifier captured from the app (stable across launches) ---
WY_USER_AGENT=WY_APP_XXXXXXXXXXXXXXXXXXXX

# --- API base URL ---
BASE_URL=https://api.advelsoft.my

# --- Booking target config ---
# Comma-separated list of bookingTypeIDs to book simultaneously (5,6,7 = Indoor Badminton Courts 1,2,3)
BOOKING_TYPE_IDS=5,6,7
ADVANCE_DAYS=14
TARGET_WEEKDAY=1
BOOKED_FROM_HOUR=20
BOOKED_TO_HOUR=22

# --- Telegram notifications ---
TELEGRAM_BOT_TOKEN=123456789:AA_your_bot_token_here
# Comma-separated list - each person must have messaged the bot at least once
TELEGRAM_CHAT_ID=6887787007

# --- Burst fallback tuning ---
BURST_INTERVAL_MS=200
BURST_MAX_DURATION_MS=8000
